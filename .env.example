# ─── Required ──────────────────────────────────────────────────────────────────

# Telegram bot token — get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID — auto-registered on first /start (or set manually)
ALLOWED_CHAT_ID=

# ─── Optional: Claude API ──────────────────────────────────────────────────────

# Only needed if you want to use a specific API key instead of `claude login` auth.
# Leave blank to use your existing Claude Code login.
ANTHROPIC_API_KEY=

# ─── Logging ───────────────────────────────────────────────────────────────────

# Log level: trace | debug | info | warn | error (default: info)
LOG_LEVEL=info
