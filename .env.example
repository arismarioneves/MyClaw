# ─── Messengers ────────────────────────────────────────────────────────────────
# At least one messenger must be configured (Telegram and/or Slack).

# Telegram — get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Your Telegram chat ID — auto-registered on first /start (or set manually)
ALLOWED_CHAT_ID=

# Slack — requires Socket Mode enabled on your Slack app
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=
# Optional: restrict Slack to a single user ID (e.g. U01234ABCDE). Leave blank for all workspace members.
ALLOWED_SLACK_USER_ID=

# ─── Connections ────────────────────────────────────────────────────────────────
# Optional integrations. Each is enabled only when its variables are set.

# Jira — Atlassian domain, email, and API token (from id.atlassian.com)
JIRA_HOST=
JIRA_EMAIL=
JIRA_API_TOKEN=

# GitHub — repository in owner/repo format. Requires gh CLI authenticated (gh auth login).
GITHUB_REPO=

# Local repo — absolute path to a git repository the agent will work on
LOCAL_REPO_PATH=

# ─── Claude API ─────────────────────────────────────────────────────────────────
# Only needed if you want a specific API key instead of `claude login` auth.
ANTHROPIC_API_KEY=

# ─── Logging ────────────────────────────────────────────────────────────────────
# trace | debug | info | warn | error (default: info)
LOG_LEVEL=info
