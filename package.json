{
  "name": "lizz",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node --no-warnings dist/index.js",
    "dev": "tsx src/index.ts",
    "setup": "tsx src/setup.ts",
    "status": "tsx src/status.ts",
    "cli": "tsx src/cli.ts",
    "test": "vitest run",
    "test:db": "node --import tsx/esm src/db.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "latest",
    "@slack/bolt": "^4.6.0",
    "axios": "^1.13.6",
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "cron-parser": "^4.9.0",
    "grammy": "^1.21.1",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "ora": "^9.3.0",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  }
}
